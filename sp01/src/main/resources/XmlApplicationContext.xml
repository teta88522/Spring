<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans" 
xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" 
xsi:schemaLocation="http://www.springframework.org/schema/beans 
http://www.springframework.org/schema/beans/spring-beans.xsd">
	<!-- Spring IoC Container에 등록할 Bean 추가 -->
	<bean class="com.yedam.app.xml.SamsungTV" />
	<bean id="tv" class="com.yedam.app.xml.LGTV" />
	
	<!-- DI 설정 -->
	<bean id="cf" class="com.yedam.app.xml.Chef" />
	<bean class="com.yedam.app.xml.Restaurant">
		<!-- Setter Injection -->
		<!-- <property name="chef" ref="cf"/> -->
		<!-- Constructor Injection -->
		<constructor-arg ref="cf"/>
	</bean>
	
</beans>